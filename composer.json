{
  "name": "jukkatawast/phpexiftool",
  "type": "library",
  "description": "Exiftool driver for PHP",
  "keywords": [
    "metadata",
    "exiftool"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Romain Neutron",
      "email": "imprec@gmail.com",
      "homepage": "http://www.lickmychip.com/"
    },
    {
      "name": "Benoit Burnichon",
      "email": "bburnichon@alchemy.fr",
      "role": "Lead Developer"
    }
  ],
  "repositories": [
    {
      "type": "package",
      "package": {
        "name": "exiftool/exiftool",
        "version": "11",
        "source": {
          "url": "https://github.com/exiftool/exiftool.git",
          "type": "git",
          "reference": "11.84"
        }
      }
    }
  ],
  "require": {
    "php": ">=8",
    "doctrine/cache": "^1.0",
    "doctrine/collections": "^1.0",
    "monolog/monolog": "^2.0|^3.0",
    "exiftool/exiftool": "^11",
    "symfony/console": "^6.0",
    "symfony/process": "^6.0|^7.0|^8.0"
  },
  "suggest": {
    "jms/serializer": "To serialize tags",
    "symfony/yaml": "To serialize tags in Yaml format"
  },
  "require-dev": {
    "jms/serializer": "~0.10|^1.0",
    "symfony/css-selector": "^4.0|^5.0",
    "symfony/dom-crawler": "^4.0|^5.0",
    "symfony/finder": "^4.0|^5.0",
    "symfony/yaml": "^4.0|^5.0"
  },
  "autoload": {
    "psr-0": {
      "PHPExiftool\\": "lib/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-master": "0.5.x-dev"
    }
  }
}
